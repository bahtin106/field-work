{
  "expo": {
    "name": "Монитор",
    "slug": "work-orders-app",
    "version": "1.0.1",
    "scheme": "workorders",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash/splashscreen_logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#F2F2F7"
    },
    "platforms": [
      "android",
      "ios"
    ],
    "userInterfaceStyle": "automatic",
    "android": {
      "package": "com.monitorapp.monitor",
      "googleServicesFile": "./android/app/google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#8FD2F7"
      }
    },
    "jsEngine": "hermes",
    "assetBundlePatterns": [
      "**/*"
    ],
    "androidStatusBar": {
      "barStyle": "dark-content",
      "backgroundColor": "#F2F2F7",
      "translucent": false
    },
    "androidNavigationBar": {
      "barStyle": "dark-content",
      "backgroundColor": "#FFFFFF"
    },
    "extra": {
      "supabaseUrl": "https://supabase.monitorapp.ru",
      "supabaseAnonKey": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiIsImlzcyI6InN1cGFiYXNlIiwiaWF0IjoxNzcwMTI0NjE4LCJleHAiOjIwODU0ODQ2MTh9.AHQIpGhGL9NH8i6v6oNs7counMqIjmbpjFNZ0BHXc4w",
      "emailServiceUrl": "https://api.monitorapp.ru",
      "eas": {
        "projectId": "3c645715-1637-4502-979c-d4690c6cf1e2"
      }
    },
    "owner": "bahtin106",
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash/splashscreen_logo.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "backgroundColor": "#F2F2F7",
          "dark": {
            "image": "./assets/splash/splashscreen_logo.png",
            "backgroundColor": "#0B0B0F"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notifications/notification-icon.png",
          "color": "#0A84FF",
          "defaultChannel": "app-notify"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Разрешите приложению доступ к камере для съёмки фото заказов"
        }
      ]
    ]
  }
}
