{
  "expo": {
    "name": "Монитор",
    "slug": "work-orders-app",
    "version": "1.0.1",
    "scheme": "workorders",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash/splashscreen_logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#F2F2F7"
    },
    "platforms": [
      "android",
      "ios",
      "web"
    ],
    "userInterfaceStyle": "automatic",
    "android": {
      "package": "com.monitorapp.monitor",
      "googleServicesFile": "./android/app/google-services.json",
      "permissions": [
        "CAMERA",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F2F2F7"
      },
      "runtimeVersion": "1.0.0"
    },
    "jsEngine": "hermes",
    "assetBundlePatterns": [
      "**/*"
    ],
    "androidStatusBar": {
      "barStyle": "dark-content",
      "backgroundColor": "#F2F2F7",
      "translucent": false
    },
    "androidNavigationBar": {
      "barStyle": "dark-content",
      "backgroundColor": "#FFFFFF"
    },
    "extra": {
      "eas": {
        "projectId": "3c645715-1637-4502-979c-d4690c6cf1e2"
      }
    },
    "owner": "bahtin106",
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash/splashscreen_logo.png",
          "imageWidth": 180,
          "resizeMode": "contain",
          "backgroundColor": "#F2F2F7",
          "dark": {
            "image": "./assets/splash/splashscreen_logo.png",
            "backgroundColor": "#F2F2F7"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notifications/notification-icon.png",
          "color": "#0A84FF",
          "defaultChannel": "app-notify"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Разрешите приложению доступ к камере для съёмки фото заказов"
        }
      ]
    ],
    "updates": {
      "url": "https://u.expo.dev/3c645715-1637-4502-979c-d4690c6cf1e2"
    },
    "ios": {}
  }
}
